# ============================================
# EMAIL CONFIGURATION
# ============================================
# SMTP server configuration for sending magic link emails
MAIL_HOST=h-town.duckdns.org
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=postmaster@sparen.mom
MAIL_PASS=your_mail_password_here
MAIL_FROM=noreply@sparen.mom

# ============================================
# AUTHENTICATION
# ============================================
# JWT secret for session tokens
# Generate a strong random value: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# ============================================
# FRONTEND (Public/Visible in Browser)
# ============================================
# Base URL for API calls from frontend
NEXT_PUBLIC_API_URL=https://game.example.com

# Base URL for sending in magic link emails
NEXT_PUBLIC_APP_URL=https://game.example.com

# Require authentication to access game
NEXT_PUBLIC_REQUIRE_AUTH=true

# Google OAuth Client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# ============================================
# CORS
# ============================================
# Allowed origins (comma-separated, or supports wildcards for subdomains)
NEXT_PUBLIC_ALLOWED_ORIGINS=https://game.example.com,https://h-town.duckdns.org

# ============================================
# DATABASE
# ============================================
# Path to SQLite database (auto-created if doesn't exist)
DATABASE_URL=.data/redline.db
